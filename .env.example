# ─────────────────────────────────────────────
# DJANGO CORE
# ─────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
USE_X_FORWARDED_HOST=True

# ─────────────────────────────────────────────
# DATABASE — SQLite default (dev) / PostgreSQL (prod)
# ─────────────────────────────────────────────
DB_ENGINE=django.db.backends.sqlite3
# DB_ENGINE=django.db.backends.postgresql
DB_NAME=db.sqlite3
# DB_NAME=anupam_bearings_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────────
# VPS / DOMAIN DEPLOYMENT
# ─────────────────────────────────────────────
# Example for a live domain:
# ALLOWED_HOSTS=anupambearings.com
# CSRF_TRUSTED_ORIGINS=https://anupambearings.com
# Set DEBUG=False in production.

# ─────────────────────────────────────────────
# EMAIL (Resend API)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=noreply@anupambearings.com
COMPANY_EMAIL=info@anupambearings.com

# ─────────────────────────────────────────────
# REDIS (Celery broker + RAG cache)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# RAG SYSTEM
# ─────────────────────────────────────────────
RAG_INDEX_DIR=data/faiss_index
RAG_KNOWLEDGE_DIR=data/knowledge_base
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.22
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────
# LLM BACKEND — choose one
# ─────────────────────────────────────────────
# 'groq'   → Free Groq API (1–3s, recommended)
LLM_BACKEND=groq
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

# Groq API (free at console.groq.com — 30 req/min free tier)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
# Other fast Groq models: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it
